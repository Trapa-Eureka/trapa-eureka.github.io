source "https://rubygems.org"

# Modern Jekyll runs cleanly on current Ruby for local preview & builds.
# NOTE: GitHub Pages builds the *deployed* site with its own pinned toolchain,
# so this Gemfile only affects what you run locally.
gem "jekyll", "~> 4.3"

# Ruby 3.0+ no longer bundles webrick, which `jekyll serve` needs for preview.
gem "webrick", "~> 1.8"

# stdlib libraries that left Ruby's defaults in 3.4 / 4.0 — pinned for stability.
gem "csv"
gem "base64"
gem "bigdecimal"
gem "logger"
