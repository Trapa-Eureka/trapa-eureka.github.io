---
# Client-side search index — generated by Liquid, no plugin required
layout: null
sitemap: false
---
[
{%- assign pages = site.pages | sort: 'order' | reverse -%}
{%- assign first = true -%}
{%- for p in pages -%}
{%- if p.projects or p.blog or p.book -%}
{%- unless first %},{% endunless -%}{%- assign first = false -%}
{%- assign desc = p.description | default: p.content | markdownify | strip_html | normalize_whitespace | truncatewords: 40 -%}
{"title": {{ p.title | jsonify }}, "subtitle": {{ p.subtitle | default: "" | jsonify }}, "type": {{ p.type | default: "" | jsonify }}, "url": {{ p.url | prepend: site.baseurl | jsonify }}, "description": {{ desc | jsonify }}}
{%- endif -%}
{%- endfor -%}
]
